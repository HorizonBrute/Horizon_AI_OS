# Horizon AIOS — Machine-Local Configuration
# Copy to horizon_system/ai_os_etc/aios_local.conf and edit. Never commit. No credentials here.

# ---------------------------------------------------------------------------
# Sync
# ---------------------------------------------------------------------------

# yes | no
SYNC_AIOS_FROM_REMOTE=yes

# hourly | daily | weekly
AIOS_SYNC_FREQ=daily

# HH:MM (24h). Used for daily/weekly; ignored for hourly.
AIOS_SYNC_TIME=03:00

# Remote name or URL to sync from.
AIOS_REPO_REMOTE=origin

# Branch to sync from. Leave blank to auto-detect the remote's default branch
# (main, master, ...) — recommended, so the sync can't break if the default
# doesn't match. Set an explicit branch only to pin a non-default one.
AIOS_REPO_BRANCH=

# ---------------------------------------------------------------------------
# Sync — unattended mode notes
# ---------------------------------------------------------------------------
# Default: runs only when logged in (uses your existing SSH agent).
# Unattended (server/always-on): use a passphrase-free SSH deploy key with
# read-only access. See $HORIZON_DOCS/sync_setup.md.

# ---------------------------------------------------------------------------
# User-data backup (memory, handoffs, objectives -> YOUR remote)
# ---------------------------------------------------------------------------
# horizon_aios_backup_user_data.py force-adds these paths to a per-machine branch on YOUR
# remote WITHOUT editing the framework .gitignore (so upstream updates never
# conflict). It REFUSES to push to the public Horizon upstream. See
# $HORIZON_DOCS/system/distribution_and_updates.md.

# Your OWN git remote (name or URL). Required for backups. Never the public upstream.
# AIOS_BACKUP_REMOTE=

# Branch to push backups to. Default: aios-backup/<hostname> (per-machine; avoids divergence).
# AIOS_BACKUP_BRANCH=

# Space-separated paths to back up. Default: memory handoffs objectives
# AIOS_BACKUP_PATHS=memory handoffs objectives

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Override log root. Default: $HORIZON_SYSTEM/logs (derived at runtime).
# AIOS_LOG_DIR=/var/log/horizon-aios

# Days before logs are pruned. 0 = disabled.
AIOS_LOG_MAX_DAYS=30

# Max MB per log file before rotation. 0 = disabled.
AIOS_LOG_MAX_SIZE_MB=10

# Rotated files to keep per log.
AIOS_LOG_MAX_ROTATIONS=5

# ---------------------------------------------------------------------------
# Handoffs
# ---------------------------------------------------------------------------

# Max total MB for handoffs/ directory. Oldest deleted first. 0 = disabled.
AIOS_HANDOFFS_MAX_SIZE_MB=500

# ---------------------------------------------------------------------------
# Objectives
# ---------------------------------------------------------------------------

# Days since last update before an objective is pruned. Updating an objective
# refreshes its clock; abandoned objectives age out. index.md is never pruned.
# 0 = disabled.
AIOS_OBJECTIVES_MAX_DAYS=90
