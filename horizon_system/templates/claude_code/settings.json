{
  "permissions": {
    "allow": [],
    "defaultMode": "acceptEdits"
  },
  "statusLine": {
    "type": "command",
    "command": "powershell.exe -NonInteractive -File 'AIOS_EXEC_WRAPPER' statusline"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& 'AIOS_EXEC_WRAPPER' hook-stop",
            "shell": "powershell"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& 'AIOS_EXEC_WRAPPER' hook-permission",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "& 'AIOS_EXEC_WRAPPER' hook-stopfailure",
            "shell": "powershell",
            "async": true
          }
        ]
      }
    ]
  },
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "theme": "dark",
  "verbose": true
}
