[user]
	name = YOUR_NAME
	email = YOUR_EMAIL
	# WARNING: gpgsign = true is set below. If you do not replace YOUR_GPG_FINGERPRINT
	# with a real key fingerprint, every commit will fail. Run: gpg --list-secret-keys
	# to find your fingerprint, then substitute it here.
	signingkey = YOUR_GPG_FINGERPRINT

[core]
	# false = no line-ending conversion; avoids LF→CRLF warnings on Windows
	autocrlf = false
	quotePath = false

[commit]
	gpgsign = true
	signoff = true

[advice]
	# All false — suppress contextual advice; show errors only
	detachedHead = false
	addIgnoredFile = false
	resolveConflict = false
	commitBeforeMerge = false
	pushUpdateRejected = false
	statusAheadBehind = false
	ignoredByPathspec = false
	waitingForEditor = false
	skippedCherryPicks = false
	addEmptyPathspec = false
	checkoutAmbiguousRemoteBranchName = false
	diverging = false
	forceDeleteBranch = false
	pushAlreadyExists = false
	pushFetchFirst = false
	pushNeedsForce = false
	statusHints = false
	statusUoption = false
	suggestDetachingHead = false
	tagFetching = false

[status]
	branch = true

[fetch]
	prune = true
