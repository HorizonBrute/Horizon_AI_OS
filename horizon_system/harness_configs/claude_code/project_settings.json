{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/devroot/horizon_system/sounds/play_sound.sh\" \"C:/devroot/horizon_system/sounds/WorkComplete_ork.wav\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
