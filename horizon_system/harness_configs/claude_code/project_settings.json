    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/devroot/horizon_system/sounds/play_sound.sh\" \"C:/devroot/horizon_system/sounds/APIFail.wav\"",
            "async": true
          }
