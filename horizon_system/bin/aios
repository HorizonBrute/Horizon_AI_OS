#!/usr/bin/env bash
# Thin wrapper — delegates to sbin/horizon_aios_switch.py
# Path-agnostic: derives sbin from this file's own location.
SBIN="$(cd "$(dirname "$0")/../sbin" && pwd)"
if command -v python3 >/dev/null 2>&1; then
    exec python3 "$SBIN/horizon_aios_switch.py" "$@"
else
    exec python "$SBIN/horizon_aios_switch.py" "$@"
fi
