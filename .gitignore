# =============================================================================
# HORIZON AIOS — session artifacts and machine-local files
# =============================================================================

# Handoff session artifacts (machine-local continuity; not version history)
# Track scaffold (.gitkeep + README.md) but not session documents.
handoffs/*
!handoffs/.gitkeep
!handoffs/README.md

# Objective artifacts (machine-local durable goals; not version history)
# Track scaffold only.
objectives/*
!objectives/.gitkeep

# Harness per-project state redirected here by redirect_memory.py: conversation
# transcripts AND agent memory (machine-local; sensitive; never committed/shipped/synced)
memory/

# Machine-local user skills (linked into skills_sbin at runtime; never tracked)
# Track the scaffold .gitkeep only so the dir exists on fresh clone.
usrbin/usr_skills/*
!usrbin/usr_skills/.gitkeep

# Machine-local config overrides (configured from templates; never committed)
*.local.json
# settings.local.json contains real machine paths — must never be committed (security_invariants §6)
.claude/settings.local.json
**/.claude/settings.local.json

# Machine-local AIOS configuration (generated from template; never committed)
horizon_system/ai_os_etc/aios_local.conf
horizon_system/ai_os_etc/aios_monitor.conf

# Machine-local git identity written by `aios setup` (user.name/email/signingkey);
# pulled in via `git config --global include.path`. Never committed (decision 2).
horizon_system/ai_os_etc/git_identity.local.gitconfig

# User-local model preferences extension (gitignored; populate from the example
# in horizon_aios_model_prefs.md and never overwritten by AIOS updates)
horizon_system/ai_os_etc/horizon_aios_model_prefs.local.md

# Machine-local agent-instruction override. Every agents.md @-imports its sibling
# local.agents.md; it ships as local.agents.md.template, is materialized by
# `aios setup`, and is never tracked or clobbered by upstream sync. Bare pattern =
# ignored in EVERY directory (root, .claude, any nested scope). The .template stays
# tracked (different name). See file_structure_invariants §12.
local.agents.md

# Machine-local agent-teams override. Every agents.md @-imports its sibling
# local.agent_teams.md; it ships as local.agent_teams.md.template, is materialized
# by `aios setup` (horizon_aios_switch.py -> setup_local_agent_teams), and is never
# tracked or clobbered by upstream sync. Bare pattern = ignored in EVERY directory
# (root, .claude, brain scope, any nested scope). The .template stays tracked
# (different name); agent_teams.md (no `local.` prefix) stays tracked.
# Materialized by `aios setup`. See file_structure_invariants §13.
local.agent_teams.md

# Machine-local agent-team FLAG registry override. agents.md @-imports it alongside
# the shipped agent_team_flags.md; ships as local.agent_team_flags.md.template,
# materialized by `aios setup`, never tracked or clobbered. See §13.
horizon_system/ai_os_etc/local.agent_team_flags.md

# Machine-local personal project ignore list (copy .gitignore.user.template → .gitignore.user)
.gitignore.user
horizon_system/harness_configs/claude_code/known_marketplaces.json
horizon_system/harness_configs/claude_code/project_settings.json

# Operational logs live at the canonical path $HORIZON_SYSTEM/logs/ — the
# scaffold there is tracked, log *content* stays gitignored (see the
# horizon_system/logs un-ignore block at the end of this file). The old
# $HORIZON_ROOT/logs/ scaffold has been retired.

# Windows Explorer metadata
desktop.ini
**/desktop.ini

# Brain folders are user-local; only scaffold and common config are tracked
brains/*
!brains/.aioscommon
!brains/.aioscommon/**

# =============================================================================
# HORIZON AIOS — explicit un-ignores (must come last)
# =============================================================================
!.gitattributes

# Un-ignore horizon_system subdirs that match generic VS/build patterns
!horizon_system/bin/
!horizon_system/bin/**
horizon_system/bin/**/__pycache__/
# Canonical operational logs scaffold ($HORIZON_SYSTEM/logs/).
# Track the directory scaffold (.gitkeep + README.md) but never log content.
# Pattern: traverse into logs/ and its subdirs, ignore their contents, then
# re-include the scaffold placeholders so empty dirs persist in the index.
!horizon_system/logs/
horizon_system/logs/*
!horizon_system/logs/.gitkeep
!horizon_system/logs/*/
horizon_system/logs/*/*
!horizon_system/logs/*/.gitkeep
!horizon_system/logs/**/README.md
