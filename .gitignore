# =============================================================================
# HORIZON AIOS — versioned config override
# The global gitignore excludes .claude/ entirely. Override that here so
# only the two versioned files are tracked; everything else stays excluded.
# =============================================================================
!.claude/
.claude/*
!.claude/CLAUDE.md
!.claude/settings.json

# User-personal ignore layer — edit .gitignore.user, not this file.
# The pre-commit hook syncs .gitignore.user -> .git/info/exclude automatically.
!.gitignore.user

